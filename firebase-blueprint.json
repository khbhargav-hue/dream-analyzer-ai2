/**
 * Defines the structure of the FirebaseBlueprint configuration.
 */
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "Stores generated Dream11 teams and analysis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID of the user who created the prediction" },
        "analysis": { "type": "string", "description": "Expert analysis text" },
        "corePlayers": {
          "type": "array",
          "description": "8 players common to all teams",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "options": {
          "type": "array",
          "description": "3 different sets of 3 differential players",
          "items": {
            "type": "object",
            "properties": {
              "variantName": { "type": "string" },
              "differentials": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "role": { "type": "string" },
                    "reason": { "type": "string" }
                  }
                }
              },
              "captain": { "type": "string" },
              "viceCaptain": { "type": "string" },
              "strategy": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "analysis", "corePlayers", "options", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Generated predictions"
    }
  }
}
